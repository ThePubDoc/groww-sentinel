# Copy to .env and fill in real values, then: set -a; source .env; set +a
# .env is gitignored — never commit real secrets.

# Groww dashboard -> TradeAPI -> TOTP-flow credentials
GROWW_API_KEY=
GROWW_TOTP_SEED=

# Telegram @BotFather -> /newbot
TELEGRAM_TOKEN=
# Message your bot once, then GET api.telegram.org/bot<TOKEN>/getUpdates -> chat.id (or @userinfobot)
TELEGRAM_CHAT_ID=
